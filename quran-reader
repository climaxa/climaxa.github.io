<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المصحف الإلكتروني - مع حفظ التقدم</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f1ea;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .quran-container {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 600px;
            width: 90%;
        }
        .surah-name {
            color: #2c5f2d;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 10px;
        }
        .ayah-text {
            font-size: 1.8rem;
            line-height: 2.5rem;
            margin: 20px 0;
            min-height: 150px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #333;
        }
        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
        }
        button {
            background-color: #2c5f2d;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.3s;
        }
        button:disabled {
            background-color: #ccc;
        }
        button:hover:not(:disabled) {
            background-color: #1e401e;
        }
        .info {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 10px;
        }
        .save-msg {
            font-size: 0.8rem;
            color: #2c5f2d;
            margin-top: 10px;
            display: block;
        }
    </style>
</head>
<body>

<div class="quran-container">
    <div id="surah-info" class="surah-name">جاري التحميل...</div>
    <div id="ayah-display" class="ayah-text">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ</div>
    
    <div class="info">
        آية رقم: <span id="ayah-number">1</span> من 6236
    </div>

    <div class="controls">
        <button id="prev-btn" onclick="changeAyah(-1)">السابقة</button>
        <button id="next-btn" onclick="changeAyah(1)">التالية</button>
    </div>
    <span class="save-msg">✓ يتم حفظ مكانك تلقائياً</span>
</div>

<script>
    // 1. محاولة استرجاع آخر آية من ذاكرة المتصفح، إذا لم توجد نبدأ من 1
    let currentAyah = parseInt(localStorage.getItem('lastAyah')) || 1;
    const totalAyahs = 6236;

    async function fetchAyah(number) {
        const display = document.getElementById('ayah-display');
        const info = document.getElementById('surah-info');
        const numDisplay = document.getElementById('ayah-number');
        
        display.innerText = "جاري التحميل...";
        
        try {
            const response = await fetch(`https://api.alquran.cloud/v1/ayah/${number}`);
            const data = await response.json();
            
            if (data.code === 200) {
                const ayah = data.data;
                display.innerText = ayah.text;
                info.innerText = `سورة ${ayah.surah.name} - آية ${ayah.numberInSurah}`;
                numDisplay.innerText = number;

                // 2. حفظ الآية الحالية في ذاكرة المتصفح فور تحميلها بنجاح
                localStorage.setItem('lastAyah', number);
            }
        } catch (error) {
            display.innerText = "حدث خطأ في الاتصال. تأكد من الإنترنت.";
        }

        document.getElementById('prev-btn').disabled = (number <= 1);
        document.getElementById('next-btn').disabled = (number >= totalAyahs);
    }

    function changeAyah(step) {
        currentAyah += step;
        if (currentAyah < 1) currentAyah = 1;
        if (currentAyah > totalAyahs) currentAyah = totalAyahs;
        fetchAyah(currentAyah);
    }

    // تحميل الآية المحفوظة عند فتح الصفحة
    fetchAyah(currentAyah);
</script>

</body>
</html>
